---
import Basepage from "@layouts/Basepage.astro";
const { lang } = Astro.props;
import { useTranslations } from "@i18n/utils";
import ProjectsCards from "@components/Pages/Projects/ProjectsCards.astro";
import ProjectsTitle from "@components/Pages/Projects/ProjectsTitle.astro";
import { defaultLang } from "@i18n/ui";
const t = useTranslations(lang);
---

<Basepage
	seo={{
		title: t("seo.projects.title"),
		description: t("seo.projects.description"),
		canonical: `https://seyron.is-a.dev/${lang === defaultLang ? "" : lang + "/"}projects/`,
		languageAlternates: [
			{
				hrefLang: "x-default",
				href: `https://seyron.is-a.dev/projects`,
			},
			{
				hrefLang: "en",
				href: `https://seyron.is-a.dev/projects`,
			},
			{
				hrefLang: "es",
				href: `https://seyron.is-a.dev/es/projects`,
			},
		],
	}}
>
	<ProjectsTitle />
	<ProjectsCards />
</Basepage>
